APP_SITE=staging.example.com
NEXT_PUBLIC_API_BASE_URL=https://staging.example.com/api
WEB_BASE_URL=https://staging.example.com
API_CORS_ORIGIN=https://staging.example.com
COOKIE_SECURE=true
COOKIE_SAMESITE=lax
TRUST_PROXY=true
TRUST_PROXY_HOPS=1

POSTGRES_DB=gst_billing
POSTGRES_USER=gst
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql://gst:change-me@postgres:5432/gst_billing?schema=public

REDIS_HOST=redis
REDIS_PORT=6379

JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000
FILE_SIGNING_SECRET=change-me-file-signing-secret

FILE_STORAGE_DRIVER=local
FILE_STORAGE_ROOT=/var/lib/vyapar-genie/storage

BILLING_STRIPE_SECRET_KEY=
BILLING_STRIPE_WEBHOOK_SECRET=
BILLING_RAZORPAY_KEY_ID=
BILLING_RAZORPAY_KEY_SECRET=
BILLING_RAZORPAY_WEBHOOK_SECRET=

NOTIFICATIONS_EMAIL_WEBHOOK_URL=
NOTIFICATIONS_SMS_WEBHOOK_URL=
NOTIFICATIONS_WHATSAPP_WEBHOOK_URL=
