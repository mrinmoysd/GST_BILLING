{
  "name": "gst-billing-software",
  "private": true,
  "version": "0.0.0",
  "packageManager": "npm@10.7.0",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "lint": "eslint .",
    "format": "prettier -w .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "jest",
    "api:dev": "npm --workspace apps/api run start:dev",
    "api:build": "npm --workspace apps/api run build",
    "api:test": "npm --workspace apps/api run test",
    "api:lint": "npm --workspace apps/api run lint",
    "api:typecheck": "npm --workspace apps/api run typecheck"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.10",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.8.0",
    "eslint-config-prettier": "^9.1.0",
    "jest": "^29.7.0",
    "prettier": "^3.3.3",
    "ts-jest": "^29.2.5",
    "typescript": "^5.5.4"
  }
}
