model SalesVisit {
  id                String    @id @default(uuid()) @db.Uuid
  companyId         String    @map("company_id") @db.Uuid
  visitPlanId       String?   @unique @map("visit_plan_id") @db.Uuid
  salespersonUserId String    @map("salesperson_user_id") @db.Uuid
  customerId        String    @map("customer_id") @db.Uuid
  territoryId       String?   @map("territory_id") @db.Uuid
  routeId           String?   @map("route_id") @db.Uuid
  beatId            String?   @map("beat_id") @db.Uuid
  visitDate         DateTime  @map("visit_date") @db.Date
  checkInAt         DateTime? @map("check_in_at") @db.Timestamptz(6)
  checkOutAt        DateTime? @map("check_out_at") @db.Timestamptz(6)
  checkInLatitude   Decimal?  @map("check_in_latitude")
  checkInLongitude  Decimal?  @map("check_in_longitude")
  checkOutLatitude  Decimal?  @map("check_out_latitude")
  checkOutLongitude Decimal?  @map("check_out_longitude")
  status            String    @default("planned") @db.VarChar(32)
  primaryOutcome    String?   @map("primary_outcome") @db.VarChar(64)
  productiveFlag    Boolean   @default(false) @map("productive_flag")
  notes             String?
  nextFollowUpDate  DateTime? @map("next_follow_up_date") @db.Date
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)

  company         Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  visitPlan       SalesVisitPlan?       @relation(fields: [visitPlanId], references: [id], onDelete: SetNull)
  salesperson     User                  @relation("SalesVisitSalesperson", fields: [salespersonUserId], references: [id], onDelete: Cascade)
  customer        Customer              @relation(fields: [customerId], references: [id], onDelete: Cascade)
  territory       SalesTerritory?       @relation(fields: [territoryId], references: [id], onDelete: SetNull)
  route           SalesRoute?           @relation(fields: [routeId], references: [id], onDelete: SetNull)
  beat            SalesBeat?            @relation(fields: [beatId], references: [id], onDelete: SetNull)
  outcomes        SalesVisitOutcome[]
  quotations      Quotation[]           @relation("SalesVisitQuotations")
  salesOrders     SalesOrder[]          @relation("SalesVisitSalesOrders")
  collectionTasks CollectionTask[]

  @@index([companyId])
  @@index([salespersonUserId])
  @@index([customerId])
  @@index([routeId])
  @@index([beatId])
  @@index([companyId, visitDate, status])
  @@map("sales_visits")
}

