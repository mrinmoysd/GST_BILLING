// Canonical Prisma schema (Phase 00+)
// ==================================
//
// This is the canonical ORM schema going forward (Option A).
// Source reference (spec stage): `docs/DB_SCHEMA.sql`.
//
// Notes:
// - This is a bootstrap minimal subset. We will expand it to full parity with DB_SCHEMA.sql
//   as part of Phase 00 migrations.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id                 String   @id @default(uuid()) @db.Uuid
  name               String
  gstin              String?  @db.VarChar(15)
  pan                String?  @db.VarChar(10)
  businessType       String   @map("business_type") @db.VarChar(32)
  address            Json?
  state              String?  @db.VarChar(100)
  stateCode          String?  @map("state_code") @db.VarChar(5)
  contact            Json?
  bankDetails        Json?    @map("bank_details")
  invoiceSettings    Json?    @map("invoice_settings")
  allowNegativeStock Boolean  @default(false) @map("allow_negative_stock")
  logoUrl            String?  @map("logo_url")
  timezone           String   @default("Asia/Kolkata") @db.VarChar(64)
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  users User[]

  roles              Role[]
  permissions        Permission[]
  sessions           Session[]
  customers          Customer[]
  suppliers          Supplier[]
  products           Product[]
  categories         Category[]
  stockMovements     StockMovement[]
  warehouses         Warehouse[]
  warehouseStocks    WarehouseStock[]
  warehouseBatchStocks WarehouseBatchStock[]
  stockTransfers     StockTransfer[]
  stockTransferItems StockTransferItem[]

  purchases           Purchase[]
  purchaseItems       PurchaseItem[]
  purchaseReturns     PurchaseReturn[]
  purchaseReturnItems PurchaseReturnItem[]

  exportJobs ExportJob[]

  invoiceSeries           InvoiceSeries[]
  priceLists              PriceList[]
  priceListItems          PriceListItem[]
  customerProductPrices   CustomerProductPrice[]
  commercialSchemes       CommercialScheme[]
  commercialAuditLogs     CommercialAuditLog[]
  productBatches          ProductBatch[]
  purchaseItemBatches     PurchaseItemBatch[]
  invoiceItemBatchAllocations InvoiceItemBatchAllocation[]
  stockTransferItemBatchAllocations StockTransferItemBatchAllocation[]
  quotations              Quotation[]
  salesOrders             SalesOrder[]
  deliveryChallans        DeliveryChallan[]
  deliveryChallanItems    DeliveryChallanItem[]
  deliveryChallanEvents   DeliveryChallanEvent[]
  invoices                Invoice[]
  eInvoiceDocuments       EInvoiceDocument[]
  eWayBillDocuments       EWayBillDocument[]
  invoiceComplianceEvents InvoiceComplianceEvent[]
  quotationItems          QuotationItem[]
  salesOrderItems         SalesOrderItem[]
  creditNotes             DocumentCreditNote[]
  creditNoteItems         DocumentCreditNoteItem[]
  documentShares          DocumentShare[]
  documentLifecycleEvents DocumentLifecycleEvent[]
  payments                Payment[]
  bankAccounts            CompanyBankAccount[]
  collectionTasks         CollectionTask[]
  salesTerritories        SalesTerritory[]
  salesRoutes             SalesRoute[]
  salesBeats              SalesBeat[]
  customerSalesCoverages  CustomerSalesCoverage[]
  salespersonRouteAssignments SalespersonRouteAssignment[]
  salesVisitPlans         SalesVisitPlan[]
  salesVisits             SalesVisit[]
  salesVisitOutcomes      SalesVisitOutcome[]
  repDailyReports         RepDailyReport[]
  bankStatementImports    BankStatementImport[]
  bankStatementLines      BankStatementLine[]
  bankReconciliationEvents BankReconciliationEvent[]
  invoiceItems            InvoiceItem[]
  idempotencyKeys         IdempotencyKey[]

  ledgers              Ledger[]
  journals             Journal[]
  journalLines         JournalLine[]
  adminAuditLogs       AdminAuditLog[]
  internalAdminActions InternalAdminAuditLog[] @relation("InternalAdminTargetCompany")

  files                 File[]
  notificationTemplates NotificationTemplate[]
  notificationOutbox    NotificationOutbox[]
  subscriptions         Subscription[]
  companyEntitlement    CompanyEntitlement?
  usageMeters           UsageMeter[]
  migrationProjects     MigrationProject[]
  importProfiles        ImportProfile[]
  importJobs            ImportJob[]
  importJobRows         ImportJobRow[]
  printTemplates        PrintTemplate[]
  printTemplateVersions PrintTemplateVersion[]
  customFieldDefinitions CustomFieldDefinition[]
  customFieldValues     CustomFieldValue[]
  outboundWebhookEndpoints OutboundWebhookEndpoint[]
  outboundWebhookDeliveries OutboundWebhookDelivery[]
  integrationApiKeys    IntegrationApiKey[]

  @@map("companies")
}

model File {
  id             String   @id @default(uuid()) @db.Uuid
  companyId      String   @map("company_id") @db.Uuid
  ownerUserId    String?  @map("owner_user_id") @db.Uuid
  type           String   @db.VarChar(64)
  storage        String   @default("local") @db.VarChar(32)
  bucket         String?
  key            String?
  url            String?
  mimeType       String?  @map("mime_type")
  sizeBytes      BigInt?  @map("size_bytes")
  checksumSha256 String?  @map("checksum_sha256")
  metadata       Json?
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  owner   User?   @relation(fields: [ownerUserId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([companyId, type])
  @@map("files")
}

model NotificationTemplate {
  id        String   @id @default(uuid()) @db.Uuid
  companyId String   @map("company_id") @db.Uuid
  code      String   @db.VarChar(64)
  channel   String   @db.VarChar(16)
  subject   String?
  body      String
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  company Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  outbox  NotificationOutbox[]

  @@unique([companyId, code, channel])
  @@index([companyId])
  @@map("notification_templates")
}

model NotificationOutbox {
  id          String    @id @default(uuid()) @db.Uuid
  companyId   String    @map("company_id") @db.Uuid
  templateId  String?   @map("template_id") @db.Uuid
  channel     String    @db.VarChar(16)
  toAddress   String?   @map("to_address")
  payload     Json?
  status      String    @default("queued") @db.VarChar(32)
  attempts    Int       @default(0)
  lastError   String?   @map("last_error")
  scheduledAt DateTime? @map("scheduled_at") @db.Timestamptz(6)
  sentAt      DateTime? @map("sent_at") @db.Timestamptz(6)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  company  Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  template NotificationTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([status, scheduledAt])
  @@map("notification_outbox")
}

model SubscriptionPlan {
  id              String   @id @default(uuid()) @db.Uuid
  code            String   @unique @db.VarChar(64)
  name            String
  priceInr        Decimal  @default(0) @map("price_inr")
  billingInterval String   @default("month") @map("billing_interval") @db.VarChar(16)
  limits          Json?
  isPublic        Boolean  @default(true) @map("is_public")
  displayOrder    Int      @default(100) @map("display_order")
  trialDays       Int      @default(30) @map("trial_days")
  allowAddOns     Boolean  @default(true) @map("allow_add_ons")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  subscriptions Subscription[]

  @@map("subscription_plans")
}

model Subscription {
  id                     String    @id @default(uuid()) @db.Uuid
  companyId              String    @map("company_id") @db.Uuid
  planId                 String?   @map("plan_id") @db.Uuid
  plan                   String?   @db.VarChar(64)
  status                 String?   @db.VarChar(32)
  startedAt              DateTime? @map("started_at") @db.Timestamptz(6)
  expiresAt              DateTime? @map("expires_at") @db.Timestamptz(6)
  trialStartedAt         DateTime? @map("trial_started_at") @db.Timestamptz(6)
  trialEndsAt            DateTime? @map("trial_ends_at") @db.Timestamptz(6)
  metadata               Json?
  provider               String?   @db.VarChar(32)
  providerSubscriptionId String?   @map("provider_subscription_id")
  createdAt              DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  company Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  planRel SubscriptionPlan? @relation(fields: [planId], references: [id], onDelete: SetNull)
  companyEntitlements CompanyEntitlement[]

  @@index([companyId])
  @@index([companyId, status])
  @@map("subscriptions")
}

model CompanyEntitlement {
  id                 String    @id @default(uuid()) @db.Uuid
  companyId          String    @unique @map("company_id") @db.Uuid
  subscriptionId     String?   @map("subscription_id") @db.Uuid
  planCode           String?   @map("plan_code") @db.VarChar(64)
  status             String    @default("inactive") @db.VarChar(32)
  effectiveLimits    Json?     @map("effective_limits")
  overrides          Json?
  billingPeriodStart DateTime? @map("billing_period_start") @db.Date
  billingPeriodEnd   DateTime? @map("billing_period_end") @db.Date
  trialStartedAt     DateTime? @map("trial_started_at") @db.Timestamptz(6)
  trialEndsAt        DateTime? @map("trial_ends_at") @db.Timestamptz(6)
  trialStatus        String    @default("not_applicable") @map("trial_status") @db.VarChar(32)
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)

  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@index([subscriptionId])
  @@index([status])
  @@index([trialStatus])
  @@map("company_entitlements")
}

model SupportTicket {
  id        String   @id @default(uuid()) @db.Uuid
  email     String?  @db.VarChar(255)
  name      String?  @db.VarChar(255)
  subject   String?  @db.VarChar(255)
  message   String
  status    String   @default("open") @db.VarChar(32)
  priority  String   @default("normal") @db.VarChar(32)
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@index([status, createdAt])
  @@map("support_tickets")
}

model UsageMeter {
  id          String   @id @default(uuid()) @db.Uuid
  companyId   String   @map("company_id") @db.Uuid
  periodStart DateTime @map("period_start") @db.Date
  periodEnd   DateTime @map("period_end") @db.Date
  key         String   @db.VarChar(64)
  value       Decimal  @default(0)
  updatedAt   DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, periodStart, periodEnd, key])
  @@index([companyId])
  @@map("usage_meters")
}

model WebhookEvent {
  id              String    @id @default(uuid()) @db.Uuid
  provider        String    @db.VarChar(32)
  eventType       String    @map("event_type") @db.VarChar(128)
  providerEventId String?   @map("provider_event_id")
  companyId       String?   @map("company_id") @db.Uuid
  payload         Json
  signature       String?
  receivedAt      DateTime  @default(now()) @map("received_at") @db.Timestamptz(6)
  processedAt     DateTime? @map("processed_at") @db.Timestamptz(6)
  status          String    @default("received") @db.VarChar(32)
  error           String?

  @@index([provider, eventType])
  @@map("webhook_events")
}

model ExportJob {
  id        String @id @default(uuid()) @db.Uuid
  companyId String @map("company_id") @db.Uuid
  type      String @db.VarChar(64)
  status    String @default("queued") @db.VarChar(16)
  params    Json?

  resultFileUrl  String? @map("result_file_url")
  resultFileName String? @map("result_file_name") @db.VarChar(255)
  error          String?

  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  startedAt  DateTime? @map("started_at") @db.Timestamptz(6)
  finishedAt DateTime? @map("finished_at") @db.Timestamptz(6)

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([companyId, type])
  @@index([companyId, status])
  @@map("export_jobs")
}

model InvoiceSeries {
  id         String   @id @default(uuid()) @db.Uuid
  companyId  String   @map("company_id") @db.Uuid
  code       String   @db.VarChar(32)
  prefix     String?  @db.VarChar(32)
  nextNumber Int      @default(1) @map("next_number")
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  company  Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invoices Invoice[]

  @@unique([companyId, code])
  @@index([companyId])
  @@map("invoice_series")
}

model Invoice {
  id                     String    @id @default(uuid()) @db.Uuid
  companyId              String    @map("company_id") @db.Uuid
  customerId             String    @map("customer_id") @db.Uuid
  migrationSourceRef     String?   @map("migration_source_ref") @db.VarChar(128)
  salespersonUserId      String?   @map("salesperson_user_id") @db.Uuid
  quotationId            String?   @map("quotation_id") @db.Uuid
  salesOrderId           String?   @map("sales_order_id") @db.Uuid
  challanId              String?   @unique @map("challan_id") @db.Uuid
  warehouseId            String?   @map("warehouse_id") @db.Uuid
  seriesId               String?   @map("series_id") @db.Uuid
  invoiceNumber          String?   @map("invoice_number") @db.VarChar(64)
  status                 String    @default("draft") @db.VarChar(16)
  customerGstin          String?   @map("customer_gstin") @db.VarChar(15)
  placeOfSupplyStateCode String?   @map("place_of_supply_state_code") @db.VarChar(5)
  issueDate              DateTime? @map("issue_date") @db.Date
  dueDate                DateTime? @map("due_date") @db.Date
  notes                  String?

  subTotal   Decimal @default(0) @map("sub_total")
  taxTotal   Decimal @default(0) @map("tax_total")
  total      Decimal @default(0)
  amountPaid Decimal @default(0) @map("amount_paid")
  balanceDue Decimal @default(0) @map("balance_due")

  pdfUrl String? @map("pdf_url")

  cancelledAt DateTime? @map("cancelled_at") @db.Timestamptz(6)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)

  company     Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer    Customer       @relation(fields: [customerId], references: [id], onDelete: Restrict)
  salesperson User?          @relation("InvoiceSalesperson", fields: [salespersonUserId], references: [id], onDelete: SetNull)
  quotation   Quotation?     @relation(fields: [quotationId], references: [id], onDelete: SetNull)
  salesOrder  SalesOrder?    @relation(fields: [salesOrderId], references: [id], onDelete: SetNull)
  challan     DeliveryChallan? @relation("DeliveryChallanInvoice", fields: [challanId], references: [id], onDelete: SetNull)
  warehouse   Warehouse?     @relation(fields: [warehouseId], references: [id], onDelete: SetNull)
  series      InvoiceSeries? @relation(fields: [seriesId], references: [id], onDelete: SetNull)

  items           InvoiceItem[]
  creditNotes     DocumentCreditNote[]
  collectionTasks CollectionTask[]
  shares          DocumentShare[]
  lifecycleEvents DocumentLifecycleEvent[] @relation("InvoiceLifecycleEvents")
  eInvoiceDocument EInvoiceDocument?
  eWayBillDocument EWayBillDocument?
  complianceEvents InvoiceComplianceEvent[]
  payments        Payment[]

  @@index([companyId])
  @@index([companyId, status])
  @@index([companyId, issueDate])
  @@index([salespersonUserId])
  @@index([quotationId])
  @@index([salesOrderId])
  @@index([challanId])
  @@index([warehouseId])
  @@map("invoices")
}

model EInvoiceDocument {
  id                 String    @id @default(uuid()) @db.Uuid
  companyId          String    @map("company_id") @db.Uuid
  invoiceId          String    @unique @map("invoice_id") @db.Uuid
  provider           String    @default("sandbox_local") @db.VarChar(64)
  status             String    @default("not_started") @db.VarChar(32)
  eligibilityStatus  String?   @map("eligibility_status") @db.VarChar(32)
  eligibilityReasons Json?     @map("eligibility_reasons")
  irn                String?   @db.VarChar(128)
  ackNo              String?   @map("ack_no") @db.VarChar(64)
  ackDate            DateTime? @map("ack_date") @db.Timestamptz(6)
  signedInvoiceJson  Json?     @map("signed_invoice_json")
  signedQrPayload    String?   @map("signed_qr_payload")
  requestPayload     Json?     @map("request_payload")
  responsePayload    Json?     @map("response_payload")
  cancellationReason String?   @map("cancellation_reason")
  cancelledAt        DateTime? @map("cancelled_at") @db.Timestamptz(6)
  lastSyncedAt       DateTime? @map("last_synced_at") @db.Timestamptz(6)
  lastError          String?   @map("last_error")
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  events  InvoiceComplianceEvent[] @relation("EInvoiceComplianceEvents")

  @@index([companyId])
  @@index([companyId, status])
  @@map("einvoice_documents")
}

model EWayBillDocument {
  id                      String    @id @default(uuid()) @db.Uuid
  companyId               String    @map("company_id") @db.Uuid
  invoiceId               String    @unique @map("invoice_id") @db.Uuid
  provider                String    @default("sandbox_local") @db.VarChar(64)
  status                  String    @default("not_started") @db.VarChar(32)
  eligibilityStatus       String?   @map("eligibility_status") @db.VarChar(32)
  eligibilityReasons      Json?     @map("eligibility_reasons")
  ewayBillNumber          String?   @map("eway_bill_number") @db.VarChar(64)
  transportMode           String?   @map("transport_mode") @db.VarChar(32)
  transporterName         String?   @map("transporter_name")
  transporterId           String?   @map("transporter_id") @db.VarChar(64)
  vehicleNumber           String?   @map("vehicle_number") @db.VarChar(64)
  distanceKm              Int?      @map("distance_km")
  transportDocumentNumber String?   @map("transport_document_number") @db.VarChar(64)
  transportDocumentDate   DateTime? @map("transport_document_date") @db.Date
  validFrom               DateTime? @map("valid_from") @db.Timestamptz(6)
  validUntil              DateTime? @map("valid_until") @db.Timestamptz(6)
  requestPayload          Json?     @map("request_payload")
  responsePayload         Json?     @map("response_payload")
  cancellationReason      String?   @map("cancellation_reason")
  cancelledAt             DateTime? @map("cancelled_at") @db.Timestamptz(6)
  lastSyncedAt            DateTime? @map("last_synced_at") @db.Timestamptz(6)
  lastError               String?   @map("last_error")
  createdAt               DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  events  InvoiceComplianceEvent[] @relation("EWayBillComplianceEvents")

  @@index([companyId])
  @@index([companyId, status])
  @@map("eway_bill_documents")
}

model InvoiceComplianceEvent {
  id               String   @id @default(uuid()) @db.Uuid
  companyId        String   @map("company_id") @db.Uuid
  invoiceId        String   @map("invoice_id") @db.Uuid
  eInvoiceDocumentId String? @map("einvoice_document_id") @db.Uuid
  eWayBillDocumentId String? @map("eway_bill_document_id") @db.Uuid
  eventType        String   @map("event_type") @db.VarChar(64)
  status           String   @default("info") @db.VarChar(24)
  summary          String
  requestPayload   Json?    @map("request_payload")
  responsePayload  Json?    @map("response_payload")
  errorMessage     String?  @map("error_message")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  company          Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invoice          Invoice           @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  eInvoiceDocument EInvoiceDocument? @relation("EInvoiceComplianceEvents", fields: [eInvoiceDocumentId], references: [id], onDelete: SetNull)
  eWayBillDocument EWayBillDocument? @relation("EWayBillComplianceEvents", fields: [eWayBillDocumentId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([invoiceId])
  @@index([companyId, createdAt])
  @@map("invoice_compliance_events")
}

model InvoiceItem {
  id               String  @id @default(uuid()) @db.Uuid
  companyId        String  @map("company_id") @db.Uuid
  invoiceId        String  @map("invoice_id") @db.Uuid
  productId        String  @map("product_id") @db.Uuid
  salesOrderItemId String? @map("sales_order_item_id") @db.Uuid

  quantity      Decimal
  freeQuantity  Decimal  @default(0) @map("free_quantity")
  totalQuantity Decimal  @default(0) @map("total_quantity")
  unitPrice     Decimal  @map("unit_price")
  discount      Decimal  @default(0)
  pricingSource   String? @map("pricing_source") @db.VarChar(64)
  pricingSnapshot Json?   @map("pricing_snapshot")
  hsnCode      String?  @map("hsn_code") @db.VarChar(32)
  taxRate      Decimal? @map("tax_rate")
  taxableValue Decimal  @default(0) @map("taxable_value")
  cgstAmount   Decimal  @default(0) @map("cgst_amount")
  sgstAmount   Decimal  @default(0) @map("sgst_amount")
  igstAmount   Decimal  @default(0) @map("igst_amount")
  cessAmount   Decimal  @default(0) @map("cess_amount")

  lineSubTotal Decimal @default(0) @map("line_sub_total")
  lineTaxTotal Decimal @default(0) @map("line_tax_total")
  lineTotal    Decimal @default(0) @map("line_total")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  company         Company                  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invoice         Invoice                  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product         Product                  @relation(fields: [productId], references: [id], onDelete: Restrict)
  salesOrderItem  SalesOrderItem?          @relation(fields: [salesOrderItemId], references: [id], onDelete: SetNull)
  creditNoteItems DocumentCreditNoteItem[]
  batchAllocations InvoiceItemBatchAllocation[]

  @@index([companyId])
  @@index([invoiceId])
  @@index([productId])
  @@index([salesOrderItemId])
  @@map("invoice_items")
}

model DocumentCreditNote {
  id         String   @id @default(uuid()) @db.Uuid
  companyId  String   @map("company_id") @db.Uuid
  invoiceId  String   @map("invoice_id") @db.Uuid
  kind       String   @default("credit_note") @db.VarChar(32)
  status     String   @default("created") @db.VarChar(32)
  noteNumber String   @map("note_number") @db.VarChar(64)
  noteDate   DateTime @map("note_date") @db.Date
  notes      String?
  restock    Boolean  @default(false)
  subTotal   Decimal  @default(0) @map("sub_total")
  taxTotal   Decimal  @default(0) @map("tax_total")
  total      Decimal  @default(0)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

